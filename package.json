    "cdp": "node cdp-server.mjs",
    "chrome-restart": "taskkill /F /IM chrome.exe 2>NUL & timeout /t 2 /nobreak & start \"\" \"C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe\" --remote-debugging-port=9222 --user-data-dir=%TEMP%\\chrome-totem-debug --no-first-run http://localhost:5173"
